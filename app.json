{
  "expo": {
    "name": "MOHZTEC Guard",
    "slug": "mohztec-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mohztec",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohztec.guard"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.mohztec.guard",
      "permissions": [
        "VIBRATE",
        "NOTIFICATIONS",
        "VIBRATE",
        "NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020617"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "13f4483d-11b0-4151-a502-8de92a78f844"
      }
    },
    "owner": "mohztec",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/13f4483d-11b0-4151-a502-8de92a78f844"
    }
  }
}
