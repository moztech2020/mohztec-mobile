

{
  "expo": {
    "name": "MOHZTEC Guard",
    "slug": "mohztec-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mohztec",
    "userInterfaceStyle": "dark", 
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohztec.guard"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.mohztec.guard",
      "permissions": [
        "VIBRATE",
        "NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#020617" 
        }
      ]
    ]
  }
}